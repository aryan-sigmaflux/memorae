# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
API_BASE_URL=https://your-domain.com

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/memorae

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook
ALLOWED_CHAT_IDS=[]

# ── AI ────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
AI_MODEL=anthropic/claude-opus-4                # any model slug from openrouter.ai/models
AI_MAX_TOKENS=1024
OPENROUTER_SITE_URL=https://your-domain.com    # optional, shown on openrouter.ai rankings
OPENROUTER_SITE_NAME=Memorae                   # optional

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# ── Toon (AI Persona) ────────────────────────────────────────────────────────
TOON_NAME=Memo
TOON_PERSONA=friendly_assistant   # friendly_assistant | professional | casual

# ── Reminders ────────────────────────────────────────────────────────────────
REMINDER_CHECK_INTERVAL_MINUTES=1
DEFAULT_TIMEZONE=UTC
